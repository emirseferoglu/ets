# Etsy API v3 — kişisel uygulama bilgileri
# Bu dosyayı `.env` olarak kopyala ve doldur:  cp .env.example .env

# App'in "keystring" değeri (Etsy dev konsolunda "API Key").
# Hem OAuth client_id olarak hem de her istekteki x-api-key header'ı olarak kullanılır.
ETSY_API_KEY=

# App'in "shared secret" değeri. Etsy (2026) artık her v3 isteğinde
# x-api-key header'ını keystring:shared_secret biçiminde istiyor. ZORUNLU.
ETSY_SHARED_SECRET=

# Etsy uygulama ayarlarında KAYITLI olan redirect URI ile birebir aynı olmalı.
# authorize.py bu adresteki portta yerel bir dinleyici açar.
# Örn: http://localhost:3003/callback
ETSY_REDIRECT_URI=http://localhost:3003/callback

# OAuth kapsamları (okuma için yeterli). Boşlukla ayır.
# Yazma (tag/başlık güncelleme) için listings_w gerekir; yalnızca okuma için
# listings_w'yi çıkarabilirsin.
ETSY_SCOPES=listings_r listings_w shops_r

# Mağaza adı (etsy.com/shop/XXXX'teki XXXX). Shop id'yi bundan buluruz.
ETSY_SHOP_NAME=

# (Opsiyonel) shop_id'yi zaten biliyorsan doğrudan gir; ETSY_SHOP_NAME'i geçersiz kılar.
ETSY_SHOP_ID=
